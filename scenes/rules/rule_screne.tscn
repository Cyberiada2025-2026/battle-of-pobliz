[node name="text" type="Label" parent="ColorRect/HBoxContainer/VBoxContainer" unique_id=363066978]
z_index = 1
custom_minimum_size = Vector2(1000, 120)
layout_mode = 2
text = "Zostałeś stworzony jako broń, mająca dać ludzkości upragnioną zemstę nad robotami, które opuściły ją tysiące lat temu.
Zdolność przeskakiwania między mechanicznymi ciałami miała ci pozwolić zniszczyć społeczeństwo całej planety od środka, ale zamiast tego pokazała ci życie wolne od antycznej nienawiści.
Wciągnąłeś niemal cały oddział w zasadzkę, ale pilot ludzkiego statku pozostał na stanowisku. Jeżeli opuści planetę z pewnością wróci z inną bronią masowej zagłady - przebicie się przez systemy zabezpieczeń staku jest jedyną nadzieją tej planety."
label_settings = SubResource("LabelSettings_uj01v")
